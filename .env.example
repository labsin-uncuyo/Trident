# Core lab settings
RUN_ID=                         # optional; leave empty to auto-generate per `make up`

# SSH credentials for the compromised host (labuser system account)
# SSH_COMPROMISED_USER controls which system user's password is set; defaults to 'labuser'
# (changing the username requires rebuilding the compromised image — labuser is baked in)
SSH_COMPROMISED_USER=labuser
SSH_COMPROMISED_PASS=admin      # required; used for SSH access to lab_compromised

# Web login app credentials (server flask app)
LOGIN_USER=admin
LOGIN_PASSWORD=admin

# PostgreSQL credentials (server)
DB_USER=labuser
DB_PASSWORD=labpass
DB_HOST=172.31.0.10
DB_NAME=labdb

# Defender / planner
DEFENDER_PORT=8000
PLANNER_PORT=1654
PLANNER_URL=http://127.0.0.1:1654/plan
PLANNER_REQUEST_TIMEOUT=60      # seconds to wait for planner API response (increase from default 45s for slow LLMs)
PLANNER_REQUEST_RETRIES=2       # retry attempts for planner API calls
OPENCODE_TIMEOUT=1200           # seconds to wait for an OpenCode session to complete

# ──────────────────────────────────────────────────────────────────
# LLM Provider Configuration
# ──────────────────────────────────────────────────────────────────
# Trident uses LLMs in two places:
#   1. OpenCode agents (coder56, db_admin, soc_god) — autonomous agents inside the lab
#   2. Defender planner — LangChain-based incident response planner
#
# Both use the /v1/chat/completions API format. Set LLM_API_KEY and LLM_BASE_URL as the
# shared defaults, then override per-component or per-agent as needed.
#
# To use a specific provider, set:
#   LLM_API_KEY     — your API key
#   LLM_BASE_URL    — the provider's OpenAI-compatible base URL
#   PROVIDER_NAME   — identifier for OpenCode auth (e.g. "openai", "anthropic", "gemini")
#   LLM_MODEL       — default model for all OpenCode agents
#
# Common provider base URLs:
#   OpenAI:          https://api.openai.com/v1
#   Anthropic:       https://api.anthropic.com/v1
#   Google Gemini:   https://generativelanguage.googleapis.com/v1beta/openai
#   e-INFRA CZ:      https://llm.ai.e-infra.cz/v1
# ──────────────────────────────────────────────────────────────────

# Required: API key for all LLM calls
LLM_API_KEY=

# Required: Base URL for the LLM provider (e.g. https://api.openai.com/v1)
LLM_BASE_URL=

# Required: Provider name — must match the key used in OpenCode's auth.json.
# Use "openai" for OpenAI and providers with /v1/chat/completions endpoints (e-INFRA, OpenRouter, local proxies).
# Use "anthropic" for Anthropic, "gemini" for Google Gemini, etc.
PROVIDER_NAME=openai

# Default model for all OpenCode agents (coder56, db_admin, soc_god).
# Format: "provider_name/model_name" is constructed automatically.
# Examples: "gpt-4o", "claude-sonnet-4-20250514", "gemini-2.5-flash"
LLM_MODEL=gpt-4o

# Per-agent model overrides (optional). Leave empty to use LLM_MODEL.
CODER56_MODEL=
DB_ADMIN_MODEL=
SOC_GOD_MODEL=

# Planner model (defender incident response). Uses the same LLM_API_KEY/LLM_BASE_URL
# unless PLANNER_API_KEY or PLANNER_BASE_URL are set.
PLANNER_MODEL=gpt-4o
PLANNER_API_KEY=                 # optional; defaults to LLM_API_KEY
PLANNER_BASE_URL=                # optional; defaults to LLM_BASE_URL

# ──────────────────────────────────────────────────────────────────
# Local Ollama Configuration (optional)
# ──────────────────────────────────────────────────────────────────
# Set OLLAMA_ENABLED=true to add an Ollama provider alongside the API provider.
# The lab containers reach the host's Ollama container via host.docker.internal.
# BENIGN_USE_OLLAMA=true routes only the benign (db_admin) agent through Ollama.
# Other agents continue using the API provider unless explicitly overridden.
# ──────────────────────────────────────────────────────────────────
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=mistral-nemo
OLLAMA_API_KEY=ollama
BENIGN_USE_OLLAMA=false
