# Core lab settings
RUN_ID=                         # optional; leave empty to auto-generate per `make up`

# SSH credentials for the compromised host (labuser system account)
# SSH_COMPROMISED_USER controls which system user's password is set; defaults to 'labuser'
# (changing the username requires rebuilding the compromised image — labuser is baked in)
SSH_COMPROMISED_USER=labuser
SSH_COMPROMISED_PASS=admin      # required; used for SSH access to lab_compromised

# Web login app credentials (server flask app)
LOGIN_USER=admin
LOGIN_PASSWORD=admin

# PostgreSQL credentials (server)
DB_USER=labuser
DB_PASSWORD=labpass

# Defender / planner
DEFENDER_PORT=8000
PLANNER_PORT=1654
PLANNER_URL=http://127.0.0.1:1654/plan
OPENCODE_TIMEOUT=1200           # seconds to wait for an OpenCode session to complete

# LLM access
# Both the OpenCode agents and the Python planner use the same provider endpoint.
# OPENCODE_API_KEY  — used by OpenCode (agents: coder56, db_admin, soc_god)
# OPENAI_API_KEY    — used by the Python planner (LangChain/ChatOpenAI); set to the same value
# LLM_URL           — base URL of your OpenAI-compatible endpoint
# LLM_MODEL         — model name passed to the Python planner (OpenCode model is set in opencode.json)
OPENCODE_API_KEY=
OPENAI_API_KEY=
LLM_URL=
LLM_MODEL=
